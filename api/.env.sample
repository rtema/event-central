# Copy to .env and adjust. Every start-up mode reads the same variables.

# --- General ---------------------------------------------------------------
ENVIRONMENT=development            # development | production
LOG_LEVEL=INFO
LOG_FORMAT=json                    # json | text  (json is collector/OpenObserve friendly)
HOST=0.0.0.0
PORT=7435

# --- Database --------------------------------------------------------------
DATABASE_URL=postgresql+psycopg://eventcentral:eventcentral@db:5432/eventcentral
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_ECHO=false

# --- Observability: OpenObserve log shipping (optional) --------------------
# When OPENOBSERVE_URL is set, a non-blocking background handler ships JSON
# logs to OpenObserve's bulk-ingest API. Otherwise logs stay on stdout (ship
# them with a collector). See src/logging_config.py.
# OPENOBSERVE_URL=http://openobserve:5080
# OPENOBSERVE_ORGANIZATION=default
# OPENOBSERVE_STREAM=event_central
# OPENOBSERVE_TOKEN=                # base64("user:password") for HTTP Basic

# --- JWT / auth ------------------------------------------------------------
# Use a strong random value of at least 32 bytes in production, e.g.
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-to-a-long-random-value-min-32-bytes
JWT_ALGORITHM=HS256
JWT_ISSUER=event-central
JWT_AUDIENCE=event-central
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000

# Separate secret for HMAC-signed file-download links.
SIGNED_URL_SECRET=change-me-to-another-long-random-value
SIGNED_URL_TTL_SECONDS=900

# One-time codes (passwordless login / password reset).
OTP_TTL_SECONDS=600
OTP_CODE_LENGTH=6

# --- Object storage (primary; always used) ---------------------------------
S3_PRIMARY_ENDPOINT=http://minio:9000
S3_PRIMARY_REGION=us-east-1
S3_PRIMARY_ACCESS_KEY=minioadmin
S3_PRIMARY_SECRET_KEY=minioadmin
S3_PRIMARY_BUCKET=event-central
S3_FORCE_PATH_STYLE=true

# --- Object storage (secondary; production dual-write safety net) ----------
# S3_SECONDARY_ENDPOINT=https://s3.eu-central-1.example.com
# S3_SECONDARY_REGION=eu-central-1
# S3_SECONDARY_ACCESS_KEY=
# S3_SECONDARY_SECRET_KEY=
# S3_SECONDARY_BUCKET=event-central-dr

# --- Restore mode ----------------------------------------------------------
# Object key of the backup to restore (or pass --key on the command line).
# RESTORE_KEY=backups/eventcentral-20260101T000000Z.dump

# --- Docker secrets --------------------------------------------------------
# Any setting above can instead be supplied as a file under /run/secrets
# (file name = lower-case field name, e.g. /run/secrets/jwt_secret). The app
# reads them automatically; do not also set the same value as an env var.
# Sensitive settings shipped as secrets in docker-compose: jwt_secret,
# signed_url_secret, s3_primary_secret_key, database_url (and db_password for
# the Postgres container). Override the directory with SECRETS_DIR if needed.
