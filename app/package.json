{
  "name": "event-central",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "deploy-preview": "node scripts/clean.js && tsc -b && TARGET=preview vite build && TARGET=preview node scripts/upload.js",
    "deploy": "node scripts/clean.js && tsc -b && TARGET=production vite build && TARGET=production node scripts/upload.js",
    "lint": "eslint .",
    "preview": "vite preview",
    "i18n:extract": "lingui extract",
    "i18n:translate": "node scripts/translate.js",
    "i18n:compile": "lingui compile",
    "translate": "npm run i18n:extract && npm run i18n:translate && npm run i18n:compile"
  },
  "dependencies": {
    "@lingui/conf": "^6.2.0",
    "@lingui/core": "^5.2.0",
    "@lingui/react": "^5.2.0",
    "@mantine/core": "^7.15.0",
    "@mantine/dates": "^7.15.0",
    "@mantine/form": "^7.15.0",
    "@mantine/hooks": "^7.15.0",
    "@mantine/modals": "^7.15.0",
    "@mantine/notifications": "^7.15.0",
    "@tabler/icons-react": "^3.26.0",
    "@tanstack/react-table": "^8.20.6",
    "axios": "^1.17.0",
    "axios-auth-refresh": "^3.3.6",
    "broadcast-channel": "^7.3.0",
    "country-flag-icons": "^1.6.17",
    "dayjs": "^1.11.13",
    "dotenv": "^17.4.2",
    "postcss-preset-mantine": "^1.18.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router": "^7.17.0",
    "swr": "^2.2.5"
  },
  "devDependencies": {
    "@lingui/babel-plugin-lingui-macro": "^5.2.0",
    "@lingui/cli": "^5.2.0",
    "@lingui/vite-plugin": "^5.2.0",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "axios-mock-adapter": "^2.1.0",
    "deepl-node": "^1.27.0",
    "gettext-parser": "^9.0.2",
    "happy-dom": "^15.11.7",
    "jsdom": "^25.0.1",
    "typescript": "^5.9.3",
    "vite": "^6.0.5",
    "vitest": "^2.1.9"
  }
}